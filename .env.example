# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
AGENTMETER_DEMO_MODE=true

# Database - Postgres is the production target. The app also ships with in-memory demo data.
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/agentmeter?schema=public

# Dodo Payments - use test keys for the hackathon demo
# Get API key from: https://app.dodopayments.com/api-keys (copy the test_ key)
# Get webhook secret from: https://app.dodopayments.com/webhooks (create endpoint for /api/dodo/webhook)
DODO_PAYMENTS_API_KEY=
DODO_PAYMENTS_WEBHOOK_KEY=
DODO_PAYMENTS_ENVIRONMENT=test_mode
DODO_STABLECOIN_METHOD=crypto
# These product IDs were created via the Dodo API for this hackathon account:
